# 카카오맵 JavaScript 키 (https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키)
# 1) 카카오 디벨로퍼스에서 앱 생성
# 2) [플랫폼] → Web 플랫폼 등록 → 사이트 도메인에 http://localhost:3000 추가
# 3) 아래에 JavaScript 키를 붙여넣고 파일명을 .env.local 로 저장
NEXT_PUBLIC_KAKAO_MAP_KEY=

# (백엔드 연동 단계에서 사용) 한국관광공사 OpenAPI 서비스키
# https://www.data.go.kr 에서 발급. 서버 사이드에서만 사용하므로 NEXT_PUBLIC_ 접두어 없이.
KTO_SERVICE_KEY=
